# FinSight AI ? Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to Git (it's in .gitignore)

# === REQUIRED ===

# Path to SQLite database file
SQLITE_DB_PATH=data/processed/finsight.db

# Directory for vector store persistence
CHROMA_PERSIST_DIR=data/processed/vector_store

# Sentence-transformers model name (CPU-friendly)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# LLM API key (Groq free tier recommended)
# Get yours at: https://console.groq.com
LLM_API_KEY=your_api_key_here

# === OPTIONAL (defaults shown) ===

# Prophet seasonality settings
PROPHET_YEARLY_SEASONALITY=true
PROPHET_WEEKLY_SEASONALITY=true

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
